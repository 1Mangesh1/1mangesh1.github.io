---
/**
 * Skeleton loader for blog post cards
 * Matches BlogCard component layout
 * @param {number} [pulse] - Animation stagger delay (1-5)
 */
interface Props {
  pulse?: number;
}

const { pulse } = Astro.props;
---

<article 
  class:list={[
    'group relative rounded-lg border border-gray-200 bg-white p-4 transition-all dark:border-gray-800 dark:bg-gray-900/50',
    'space-y-3'
  ]}
>
  {/* Skeleton hero image */}
  <div 
    class:list={[
      'skeleton',
      'w-full h-40 rounded-md',
      pulse && `skeleton-pulse-${pulse}`
    ]}
  />
  
  {/* Skeleton title */}
  <div 
    class:list={[
      'skeleton',
      'skeleton-text w-3/4 h-5',
      pulse && `skeleton-pulse-${pulse}`
    ]}
  />
  
  {/* Skeleton description lines */}
  <div class="space-y-2">
    <div 
      class:list={[
        'skeleton',
        'skeleton-text w-full h-4',
        pulse && `skeleton-pulse-${pulse}`
      ]}
    />
    <div 
      class:list={[
        'skeleton',
        'skeleton-text w-5/6 h-4',
        pulse && `skeleton-pulse-${pulse}`
      ]}
    />
  </div>
  
  {/* Skeleton metadata (date, tags, read time) */}
  <div class="flex items-center justify-between gap-2 pt-2">
    <div 
      class:list={[
        'skeleton',
        'skeleton-text w-24 h-3',
        pulse && `skeleton-pulse-${pulse}`
      ]}
    />
    <div 
      class:list={[
        'skeleton',
        'skeleton-text w-16 h-3',
        pulse && `skeleton-pulse-${pulse}`
      ]}
    />
  </div>
</article>
