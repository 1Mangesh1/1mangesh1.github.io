---
/**
 * Skeleton loader for code snippet cards
 * Matches SnippetCard component layout
 * @param {number} [pulse] - Animation stagger delay (1-5)
 */
interface Props {
  pulse?: number;
}

const { pulse } = Astro.props;
---

<article 
  class:list={[
    'group relative rounded-lg border border-gray-200 bg-white p-3 transition-all hover:shadow-md dark:border-gray-800 dark:bg-gray-900/50',
    'space-y-2'
  ]}
>
  {/* Skeleton language tag */}
  <div 
    class:list={[
      'skeleton',
      'skeleton-button w-16 h-5 rounded-full inline-block text-xs',
      pulse && `skeleton-pulse-${pulse}`
    ]}
  />
  
  {/* Skeleton title */}
  <div 
    class:list={[
      'skeleton',
      'skeleton-text w-3/4 h-4',
      pulse && `skeleton-pulse-${pulse}`
    ]}
  />
  
  {/* Skeleton description */}
  <div 
    class:list={[
      'skeleton',
      'skeleton-text w-full h-3 text-sm',
      pulse && `skeleton-pulse-${pulse}`
    ]}
  />
  
  {/* Skeleton code preview lines */}
  <div class="space-y-1 py-2">
    <div 
      class:list={[
        'skeleton',
        'skeleton-text w-5/6 h-3 text-xs font-mono',
        pulse && `skeleton-pulse-${pulse}`
      ]}
    />
    <div 
      class:list={[
        'skeleton',
        'skeleton-text w-4/5 h-3 text-xs font-mono',
        pulse && `skeleton-pulse-${pulse}`
      ]}
    />
    <div 
      class:list={[
        'skeleton',
        'skeleton-text w-3/4 h-3 text-xs font-mono',
        pulse && `skeleton-pulse-${pulse}`
      ]}
    />
  </div>
  
  {/* Skeleton tags */}
  <div class="flex flex-wrap gap-1">
    <div 
      class:list={[
        'skeleton',
        'skeleton-button w-12 h-5 rounded text-xs',
        pulse && `skeleton-pulse-${pulse}`
      ]}
    />
    <div 
      class:list={[
        'skeleton',
        'skeleton-button w-14 h-5 rounded text-xs',
        pulse && `skeleton-pulse-${pulse}`
      ]}
    />
  </div>
</article>
