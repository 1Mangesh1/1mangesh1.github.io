---
/**
 * Skeleton loader for book cards
 * Matches BookCard component layout
 * @param {number} [pulse] - Animation stagger delay (1-5)
 */
interface Props {
  pulse?: number;
}

const { pulse } = Astro.props;
---

<article 
  class:list={[
    'group relative rounded-lg border border-gray-200 bg-white p-3 transition-all hover:shadow-md dark:border-gray-800 dark:bg-gray-900/50',
    'space-y-2'
  ]}
>
  {/* Skeleton book cover */}
  <div 
    class:list={[
      'skeleton',
      'w-full h-40 rounded-md',
      pulse && `skeleton-pulse-${pulse}`
    ]}
  />
  
  {/* Skeleton title */}
  <div 
    class:list={[
      'skeleton',
      'skeleton-text w-full h-4',
      pulse && `skeleton-pulse-${pulse}`
    ]}
  />
  
  {/* Skeleton author */}
  <div 
    class:list={[
      'skeleton',
      'skeleton-text w-3/4 h-3 text-sm',
      pulse && `skeleton-pulse-${pulse}`
    ]}
  />
  
  {/* Skeleton rating and status */}
  <div class="flex items-center justify-between gap-2 pt-1">
    <div 
      class:list={[
        'skeleton',
        'skeleton-button w-12 h-5 rounded',
        pulse && `skeleton-pulse-${pulse}`
      ]}
    />
    <div 
      class:list={[
        'skeleton',
        'skeleton-button w-16 h-5 rounded',
        pulse && `skeleton-pulse-${pulse}`
      ]}
    />
  </div>
</article>
