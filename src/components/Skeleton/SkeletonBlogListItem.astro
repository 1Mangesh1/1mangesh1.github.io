---
/**
 * Skeleton loader for blog list items (not cards)
 * Used in blog pagination listing where there are no hero images
 * @param {number} [pulse] - Animation stagger delay (1-5)
 */
interface Props {
  pulse?: number;
}

const { pulse } = Astro.props;
---

<article class="border-b border-gray-200 dark:border-gray-700 pb-8 last:border-b-0">
  <div class="flex flex-col space-y-3">
    {/* Skeleton title */}
    <div
      class:list={[
        'skeleton',
        'skeleton-text w-2/3 h-6',
        pulse && `skeleton-pulse-${pulse}`
      ]}
    />
    
    {/* Skeleton metadata line (date + reading time) */}
    <div class="flex items-center gap-2">
      <div
        class:list={[
          'skeleton',
          'skeleton-text w-32 h-4',
          pulse && `skeleton-pulse-${pulse}`
        ]}
      />
      <span class="text-gray-600 dark:text-gray-400">•</span>
      <div
        class:list={[
          'skeleton',
          'skeleton-text w-24 h-4',
          pulse && `skeleton-pulse-${pulse}`
        ]}
      />
    </div>
    
    {/* Skeleton description (multiple lines) */}
    <div class="space-y-2">
      <div
        class:list={[
          'skeleton',
          'skeleton-text w-full h-4',
          pulse && `skeleton-pulse-${pulse}`
        ]}
      />
      <div
        class:list={[
          'skeleton',
          'skeleton-text w-full h-4',
          pulse && `skeleton-pulse-${pulse}`
        ]}
      />
      <div
        class:list={[
          'skeleton',
          'skeleton-text w-3/4 h-4',
          pulse && `skeleton-pulse-${pulse}`
        ]}
      />
    </div>
  </div>
</article>
