---
/**
 * Skeleton loader for resource cards (large format)
 * Matches ResourceCard component layout
 * @param {number} [pulse] - Animation stagger delay (1-5)
 */
interface Props {
  pulse?: number;
}

const { pulse } = Astro.props;
---

<article 
  class:list={[
    'group relative rounded-lg border border-gray-200 bg-white p-4 transition-all hover:shadow-md dark:border-gray-800 dark:bg-gray-900/50',
    'space-y-3'
  ]}
>
  {/* Skeleton resource type tag */}
  <div 
    class:list={[
      'skeleton',
      'skeleton-button w-20 h-5 rounded-full inline-block text-xs',
      pulse && `skeleton-pulse-${pulse}`
    ]}
  />
  
  {/* Skeleton title (larger) */}
  <div 
    class:list={[
      'skeleton',
      'skeleton-text w-full h-5',
      pulse && `skeleton-pulse-${pulse}`
    ]}
  />
  
  {/* Skeleton description (multiple lines for larger resource cards) */}
  <div class="space-y-2">
    <div 
      class:list={[
        'skeleton',
        'skeleton-text w-full h-4',
        pulse && `skeleton-pulse-${pulse}`
      ]}
    />
    <div 
      class:list={[
        'skeleton',
        'skeleton-text w-full h-4',
        pulse && `skeleton-pulse-${pulse}`
      ]}
    />
    <div 
      class:list={[
        'skeleton',
        'skeleton-text w-4/5 h-4',
        pulse && `skeleton-pulse-${pulse}`
      ]}
    />
  </div>
  
  {/* Skeleton metadata (date, etc) */}
  <div 
    class:list={[
      'skeleton',
      'skeleton-text w-32 h-3 text-xs pt-1',
      pulse && `skeleton-pulse-${pulse}`
    ]}
  />
</article>
