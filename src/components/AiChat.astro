---
// src/components/AiChat.astro
---

<style>
  #ai-chat-container {
    --primary-blue: #3b82f6;
    --emerald: #10b981;
    --text-primary: #1f2937;
    --text-secondary: #6b7280;
    --bg-light: #ffffff;
    --bg-dark: #111827;
    --border-light: #e5e7eb;
    --border-dark: #374151;
  }

  #ai-chat-button {
    background: var(--primary-blue);
    color: white;
    border: none;
    border-radius: 12px;
    padding: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.15);
  }

  #ai-chat-button:hover {
    background: #0d47a1;
    box-shadow: 0 6px 16px rgba(59, 130, 246, 0.25);
    transform: translateY(-2px);
  }

  #ai-chat-button:active {
    transform: translateY(0);
  }

  #ai-chat-window {
    background: var(--bg-light);
    border: 1px solid var(--border-light);
    border-radius: 12px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  :global(.dark) #ai-chat-window {
    background: var(--bg-dark);
    border-color: var(--border-dark);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  }

  .ai-header {
    background: linear-gradient(135deg, var(--primary-blue) 0%, #1e40af 100%);
    color: white;
    padding: 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: none;
  }

  .ai-header-title {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  #ai-chat-close {
    background: rgba(255, 255, 255, 0.2);
    border: none;
    color: white;
    border-radius: 6px;
    padding: 0.5rem;
    cursor: pointer;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #ai-chat-close:hover {
    background: rgba(255, 255, 255, 0.3);
  }

  #ai-chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: var(--bg-light);
    color: var(--text-primary);
  }

  :global(.dark) #ai-chat-messages {
    background: var(--bg-dark);
    color: #f3f4f6;
  }

  .ai-message-wrapper {
    display: flex;
    margin-bottom: 1rem;
    animation: slideIn 0.3s ease-out;
    align-items: flex-end;
    gap: 0.5rem;
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .ai-message {
    padding: 0.75rem 1rem;
    border-radius: 12px;
    font-size: 0.95rem;
    line-height: 1.4;
    max-width: 75%;
    word-wrap: break-word;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
  }

  .ai-message-user {
    background: var(--primary-blue);
    color: white;
    margin-left: auto;
    border-radius: 12px 4px 12px 12px;
    font-weight: 500;
  }

  .ai-message-assistant {
    background: #f0f4f8;
    color: #1f2937;
    border-radius: 4px 12px 12px 12px;
    margin-right: auto;
  }

  :global(.dark) .ai-message-assistant {
    background: #2a3f5f;
    color: #e5e7eb;
  }

  .ai-message-error {
    background: #fee2e2;
    color: #991b1b;
    border-radius: 4px 12px 12px 12px;
    margin-right: auto;
  }

  :global(.dark) .ai-message-error {
    background: rgba(220, 38, 38, 0.15);
    color: #fca5a5;
  }

  #ai-chat-welcome {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    animation: fadeIn 0.4s ease-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .ai-welcome-text {
    color: #6b7280;
    font-size: 0.95rem;
    line-height: 1.5;
    padding: 0.75rem 1rem;
    background: #f0f4f8;
    border-radius: 12px;
    border-left: 3px solid var(--primary-blue);
  }

  :global(.dark) .ai-welcome-text {
    color: #d1d5db;
    background: #2a3f5f;
  }

  .ai-suggestions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .ai-suggestion-chip {
    background: var(--border-light);
    border: 1px solid var(--border-light);
    color: var(--primary-blue);
    padding: 0.75rem 1rem;
    border-radius: 8px;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: left;
    font-weight: 500;
  }

  .ai-suggestion-chip:hover {
    background: #eff6ff;
    border-color: var(--primary-blue);
    transform: translateX(4px);
  }

  :global(.dark) .ai-suggestion-chip {
    background: var(--border-dark);
    border-color: var(--border-dark);
    color: #bfdbfe;
  }

  :global(.dark) .ai-suggestion-chip:hover {
    background: rgba(59, 130, 246, 0.1);
    border-color: #3b82f6;
  }

  .ai-message.ai-typing-indicator {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    padding: 0.75rem 1rem;
  }

  .ai-typing-dot {
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 50%;
    background: currentColor;
    animation: typingBounce 1.2s infinite;
  }

  .ai-typing-dot:nth-child(2) {
    animation-delay: 0.2s;
  }

  .ai-typing-dot:nth-child(3) {
    animation-delay: 0.4s;
  }

  @keyframes typingBounce {
    0%, 60%, 100% {
      transform: translateY(0);
      opacity: 0.6;
    }
    30% {
      transform: translateY(-6px);
      opacity: 1;
    }
  }

  .ai-input-area {
    padding: 1.25rem;
    border-top: 1px solid var(--border-light);
    background: var(--bg-light);
  }

  :global(.dark) .ai-input-area {
    border-top-color: var(--border-dark);
    background: var(--bg-dark);
  }

  #ai-chat-form {
    display: flex;
    gap: 0.75rem;
    align-items: flex-end;
  }

  .ai-input-wrapper {
    flex: 1;
    background: var(--border-light);
    border: 1px solid var(--border-light);
    border-radius: 8px;
    overflow: hidden;
    transition: all 0.2s ease;
  }

  .ai-input-wrapper:focus-within {
    border-color: var(--primary-blue);
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
  }

  :global(.dark) .ai-input-wrapper {
    background: var(--border-dark);
    border-color: var(--border-dark);
  }

  :global(.dark) .ai-input-wrapper:focus-within {
    border-color: var(--primary-blue);
  }

  #ai-chat-input {
    width: 100%;
    background: transparent;
    border: none;
    padding: 0.75rem;
    color: var(--text-primary);
    font-size: 0.95rem;
    font-family: inherit;
    resize: none;
    overflow: hidden;
    min-height: 44px;
    max-height: 100px;
    outline: none;
  }

  :global(.dark) #ai-chat-input {
    color: #f3f4f6;
  }

  #ai-chat-input::placeholder {
    color: var(--text-secondary);
  }

  :global(.dark) #ai-chat-input::placeholder {
    color: #9ca3af;
  }

  #ai-chat-submit {
    background: var(--primary-blue);
    border: none;
    color: white;
    padding: 0.65rem;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  #ai-chat-submit:hover:not(:disabled) {
    background: #1e40af;
    box-shadow: 0 4px 8px rgba(59, 130, 246, 0.2);
    transform: translateY(-1px);
  }

  #ai-chat-submit:active:not(:disabled) {
    transform: translateY(0);
  }

  #ai-chat-submit:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .ai-counter {
    text-align: right;
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  :global(.dark) .ai-counter {
    color: #9ca3af;
  }
</style>

<script>
  const WORKER_URL = 'https://portfolio-ai-proxy.mangeshbide1.workers.dev';
  const MESSAGE_REQUEST_KEY = 'ai_msg_timestamps';
  const RATE_LIMIT_PER_HOUR = 40;

  // Generate a unique session ID for this visitor's conversation
  const SESSION_ID = crypto.randomUUID();

  // Store message timestamps in localStorage
  function getMessageTimestamps(): number[] {
    const stored = localStorage.getItem(MESSAGE_REQUEST_KEY);
    if (!stored) return [];
    const timestamps = JSON.parse(stored);
    return timestamps.filter((t: number) => Date.now() - t < 3600000); // Keep last hour only
  }

  function canSendMessage(): boolean {
    const timestamps = getMessageTimestamps();
    return timestamps.length < RATE_LIMIT_PER_HOUR;
  }

  function recordMessage(): void {
    const timestamps = getMessageTimestamps();
    timestamps.push(Date.now());
    localStorage.setItem(MESSAGE_REQUEST_KEY, JSON.stringify(timestamps));
  }

  function getRemainingMessages(): number {
    const timestamps = getMessageTimestamps();
    return Math.max(0, RATE_LIMIT_PER_HOUR - timestamps.length);
  }

  // DOM elements with proper null assertions
  const button = document.getElementById('ai-chat-button')!;
  const window_elem = document.getElementById('ai-chat-window')!;
  const closeBtn = document.getElementById('ai-chat-close')!;
  const messagesContainer = document.getElementById('ai-chat-messages')!;
  const form = document.getElementById('ai-chat-form')!;
  const input = document.getElementById('ai-chat-input') as HTMLTextAreaElement;
  const submitBtn = document.getElementById('ai-chat-submit') as HTMLButtonElement;
  const counter = document.getElementById('ai-chat-counter')!;
  const welcomeDiv = document.getElementById('ai-chat-welcome')!;
  const suggestionChips = document.querySelectorAll('.ai-suggestion-chip');
  
  let typingElement: HTMLElement | null = null;

  // Toggle chat window
  button.addEventListener('click', () => {
    const isHidden = window_elem.classList.contains('hidden');
    if (isHidden) {
      window_elem.classList.remove('hidden');
      setTimeout(() => {
        window_elem.classList.add('scale-100', 'opacity-100');
        window_elem.classList.remove('scale-95', 'opacity-0');
      }, 10);
      input.focus();
    } else {
      closeChatWindow();
    }
  });

  closeBtn.addEventListener('click', closeChatWindow);

  function closeChatWindow(): void {
    window_elem.classList.remove('scale-100', 'opacity-100');
    window_elem.classList.add('scale-95', 'opacity-0');
    setTimeout(() => window_elem.classList.add('hidden'), 300);
  }

  // Auto-resize textarea
  input.addEventListener('input', () => {
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 100) + 'px';
    
    // Update counter and button state
    const length = input.value.trim().length;
    if (counter) counter.textContent = `${length} / 300`;
    submitBtn.disabled = length === 0 || !canSendMessage();
  });

  // Handle form submission
  form.addEventListener('submit', async (e: Event) => {
    e.preventDefault();
    const message = input.value.trim();
    
    if (!message || !canSendMessage()) return;

    // Check rate limit
    if (!canSendMessage()) {
      addMessage(
        `Rate limited: ${getRemainingMessages()} requests remaining this hour`,
        'error'
      );
      return;
    }

    recordMessage();
    addMessage(message, 'user');
    input.value = '';
    input.style.height = 'auto';
    submitBtn.disabled = true;
    if (counter) counter.textContent = '0 / 300';

    showTypingIndicator();

    try {
      const response = await fetch(WORKER_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          question: message,
          sessionId: SESSION_ID,
        }),
      });

      hideTypingIndicator();

      if (!response.ok) {
        if (response.status === 429) {
          addMessage('Rate limited. Try again later.', 'error');
        } else {
          addMessage('Error fetching response. Please try again.', 'error');
        }
        return;
      }

      const data = await response.json();
      const aiMessage = data.result || 'No response received';
      addMessage(aiMessage, 'assistant');
    } catch (error) {
      hideTypingIndicator();
      addMessage('Connection error. Please check your internet.', 'error');
    } finally {
      submitBtn.disabled = false;
    }
  });

  // Add message to chat
  function addMessage(text: string, role: string): void {
    if (welcomeDiv && welcomeDiv.parentElement === messagesContainer) {
      welcomeDiv.remove();
    }

    const wrapper = document.createElement('div');
    wrapper.className = 'ai-message-wrapper';

    const bubble = document.createElement('div');
    bubble.className = `ai-message ai-message-${role}`;
    bubble.textContent = text;

    wrapper.appendChild(bubble);
    messagesContainer.appendChild(wrapper);
    messagesContainer.scrollTop = messagesContainer.scrollHeight;
  }

  // Show typing indicator as a message bubble
  function showTypingIndicator(): void {
    if (welcomeDiv && welcomeDiv.parentElement === messagesContainer) {
      welcomeDiv.remove();
    }

    const wrapper = document.createElement('div');
    wrapper.className = 'ai-message-wrapper';

    const bubble = document.createElement('div');
    bubble.className = 'ai-message ai-typing-indicator';
    
    const dot1 = document.createElement('span');
    dot1.className = 'ai-typing-dot';
    const dot2 = document.createElement('span');
    dot2.className = 'ai-typing-dot';
    const dot3 = document.createElement('span');
    dot3.className = 'ai-typing-dot';

    bubble.appendChild(dot1);
    bubble.appendChild(dot2);
    bubble.appendChild(dot3);

    wrapper.appendChild(bubble);
    typingElement = wrapper;
    messagesContainer.appendChild(wrapper);
    messagesContainer.scrollTop = messagesContainer.scrollHeight;
  }

  // Remove typing indicator
  function hideTypingIndicator(): void {
    if (typingElement && typingElement.parentElement === messagesContainer) {
      typingElement.remove();
      typingElement = null;
    }
  }

  // Handle suggestion chips
  suggestionChips.forEach(chip => {
    chip.addEventListener('click', () => {
      input.value = chip.textContent || '';
      input.style.height = 'auto';
      input.style.height = input.scrollHeight + 'px';
      submitBtn.disabled = false;
      input.focus();
    });
  });

  // Handle haptics if available
  function triggerHaptic(): void {
    const haptics = (window as any).haptics;
    if (haptics?.nudge) {
      haptics.nudge();
    }
  }

  button.addEventListener('click', triggerHaptic);
  suggestionChips.forEach(chip => {
    chip.addEventListener('click', triggerHaptic);
  });
  form.addEventListener('submit', triggerHaptic);
</script>

<div id="ai-chat-container" class="fixed bottom-6 right-6 z-50">
  
  <!-- Chat Button -->
  <button 
    id="ai-chat-button" 
    aria-label="Open AI Chat"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
    </svg>
  </button>

  <!-- Chat Window -->
  <div 
    id="ai-chat-window" 
    class="hidden absolute bottom-20 right-0 w-[calc(100vw-3rem)] sm:w-[420px] h-[540px] flex flex-col transition-all duration-300 origin-bottom-right transform scale-95 opacity-0"
  >
    <!-- Header -->
    <div class="ai-header">
      <span class="ai-header-title">Ask Mangesh</span>
      <button id="ai-chat-close">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </button>
    </div>

    <!-- Message Area -->
    <div id="ai-chat-messages" class="flex-1 overflow-y-auto">
      
      <!-- Welcome Message -->
      <div id="ai-chat-welcome" class="flex flex-col gap-1">
        <div class="ai-message ai-message-assistant">
          Hi! I'm here to answer questions about Mangesh's skills, projects, and experience.
        </div>
        
        <div class="ai-suggestions">
          <button class="ai-suggestion-chip">What are your top skills?</button>
          <button class="ai-suggestion-chip">Tell me about your projects</button>
          <button class="ai-suggestion-chip">Are you available for work?</button>
        </div>
      </div>
      
    </div>

    <!-- Input Area -->
    <div class="ai-input-area">
      <form id="ai-chat-form">
        <div class="ai-input-wrapper">
          <textarea 
            id="ai-chat-input" 
            rows="1"
            placeholder="Ask something..." 
            maxlength="300"
          ></textarea>
        </div>
        <button 
          id="ai-chat-submit"
          type="submit" 
          disabled
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z" />
          </svg>
        </button>
      </form>
      <div class="ai-counter">
        <span id="ai-chat-counter">0 / 300</span>
      </div>
      <p class="text-xs text-gray-400 dark:text-gray-500 mt-2">
        Chats may be logged to improve the experience.
      </p>
    </div>
  </div>
</div>

