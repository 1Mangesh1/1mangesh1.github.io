---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.draft !== true);
  const tags = new Set<string>();
  posts.forEach(post => {
    post.data.tags?.forEach(tag => tags.add(tag.toLowerCase().replace(/\s+/g, '-')));
  });
  return Array.from(tags).map(tag => ({ params: { tag } }));
}

const { tag } = Astro.params;
const posts = await getCollection('blog', ({ data }) => data.draft !== true);

const originalTag = posts
  .flatMap(p => p.data.tags || [])
  .find(t => t.toLowerCase().replace(/\s+/g, '-') === tag) || tag;

const tagged = posts
  .filter(p => p.data.tags?.some(t => t.toLowerCase().replace(/\s+/g, '-') === tag))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const fmt = (d: Date) =>
  new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' }).format(d);
---

<Layout title={`Tagged: ${originalTag} — Mangesh Bide`} description={`Posts tagged ${originalTag}`}>
  <div class="max-w-2xl mx-auto px-6 pt-16 pb-8">
    <h1 class="font-serif text-3xl font-bold tracking-tight mb-2">
      Tagged: <span class="text-forest dark:text-forest-dark">{originalTag}</span>
    </h1>
    <p class="text-ink-muted dark:text-neutral-400 text-sm">
      {tagged.length} {tagged.length === 1 ? 'post' : 'posts'}.
    </p>
  </div>

  <ul class="max-w-2xl mx-auto px-6 pb-16 space-y-4">
    {tagged.map(post => (
      <li class="flex items-baseline justify-between gap-6">
        <a href={`/blog/${post.id}`} class="text-ink dark:text-neutral-100 hover:text-forest dark:hover:text-forest-dark underline underline-offset-4 decoration-transparent hover:decoration-forest/50 dark:hover:decoration-forest-dark/50">
          {post.data.title}
        </a>
        <time datetime={post.data.pubDate.toISOString()} class="shrink-0 text-sm text-ink-muted dark:text-neutral-500 font-mono">
          {fmt(post.data.pubDate)}
        </time>
      </li>
    ))}
  </ul>

  <nav class="max-w-2xl mx-auto px-6 pb-16 text-sm">
    <a href="/blog" class="text-ink-muted dark:text-neutral-400 hover:text-forest dark:hover:text-forest-dark">← All posts</a>
  </nav>
</Layout>
