---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry, render } from 'astro:content';
import CopyCode from '../../components/CopyCode.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.draft !== true);
  return posts.map(post => ({ params: { slug: post.id } }));
}

const { slug } = Astro.params;
const post = await getEntry('blog', slug!);
if (!post) return Astro.redirect('/404');

const { Content } = await render(post);

const fmt = (d: Date) =>
  new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(d);

const showUpdated =
  post.data.updatedDate &&
  post.data.updatedDate.getTime() !== post.data.pubDate.getTime();
---

<Layout
  title={`${post.data.title} — Mangesh Bide`}
  description={post.data.description}
  image={post.data.ogImage || '/og-image.png'}
>
  <article class="max-w-2xl mx-auto px-6 pt-16 pb-8">
    <header class="mb-10">
      <h1 class="font-serif text-3xl md:text-4xl font-bold tracking-tight leading-tight mb-4">
        {post.data.title}
      </h1>
      <div class="text-sm text-ink-muted dark:text-neutral-500 font-mono">
        <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
        {showUpdated && <span> · updated {fmt(post.data.updatedDate!)}</span>}
      </div>
    </header>

    <div class="prose dark:prose-invert">
      <Content />
    </div>

    {post.data.tags && post.data.tags.length > 0 && (
      <footer class="mt-16 pt-6 border-t border-neutral-200 dark:border-neutral-800 text-sm text-ink-muted dark:text-neutral-500">
        Tagged: {post.data.tags.map((tag, i) => (
          <>
            {i > 0 && <span>, </span>}
            <a
              href={`/blog/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`}
              class="hover:text-forest dark:hover:text-forest-dark underline underline-offset-4 decoration-transparent hover:decoration-forest/50 dark:hover:decoration-forest-dark/50"
            >{tag}</a>
          </>
        ))}
      </footer>
    )}

    <nav class="mt-8 text-sm">
      <a href="/blog" class="text-ink-muted dark:text-neutral-400 hover:text-forest dark:hover:text-forest-dark">← All posts</a>
    </nav>
  </article>

  <CopyCode />
</Layout>
