---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Not found — Mangesh Bide" description="This page doesn't exist." noindex={true}>
  <div class="max-w-2xl mx-auto px-6 pt-24 pb-24">
    <h1 class="font-serif text-3xl font-bold tracking-tight mb-3">Not found.</h1>
    <p class="text-ink-muted dark:text-neutral-400">
      The page you're looking for doesn't exist. Try
      <a href="/" class="text-forest dark:text-forest-dark underline underline-offset-4">home</a>
      or
      <a href="/blog" class="text-forest dark:text-forest-dark underline underline-offset-4">the blog</a>.
    </p>
  </div>
</Layout>
