---
import Layout from '../layouts/Layout.astro';

const technologies = ['Python', 'JavaScript', 'Django', 'TensorFlow', 'React', 'Astro', 'Docker', 'Git', 'Node.js', 'Express', 'Socket.io', 'NestJS', 'TypeORM', 'JWT', 'Terraform', 'AWS']
---

<Layout title="About | Mangesh Bide" description="About Mangesh Bide — software engineer working across Python, JavaScript, React, Django, AI, Machine Learning and cloud infra.">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <div class="prose prose-lg dark:prose-invert max-w-none">
      <h1>About Me</h1>
      
      <div class="flex flex-col md:flex-row gap-8 items-start mb-8">
        <div class="md:w-1/3">
          <div class="w-full max-w-sm mx-auto">
            <img src="/me.jpg" alt="Mangesh Bide" class="w-full aspect-square object-cover rounded-lg shadow-lg">
          </div>
        </div>
        <div class="md:w-2/3">
          <p class="text-xl text-gray-800 dark:text-gray-200 mb-4 font-medium leading-relaxed">
            I'm Mangesh — a software engineer from India who works across the stack.
          </p>
          
          <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
            I've built multi-tenant SaaS systems, React frontends, deployed microservices on Docker, small machine learning models, and write about it all
            so others don't have to figure it out the hard way.
          </p>
        </div>
      </div>

      <h2>How I got here</h2>
      <p>
        I got into programming because I wanted to understand how video games worked. Started self-taught,
        then did a CS degree to fill in the gaps.
      </p>
      <p>
        Since then I've built web apps, ML systems, and a lot of stuff in between. The most useful thing I've
        picked up is that writing code other people can actually maintain matters more than being clever.
      </p>

      <h2>What I spend my time on</h2>
      <ul>
        <li>Full-stack apps — Django and Node on the backend, React and Astro on the frontend</li>
        <li>ML projects with TensorFlow</li>
        <li>AI powered small apps</li>
        <li>Writing about things I figure out (so I don't forget, mostly)</li>
        <li>Small tools that automate stuff I got tired of doing manually</li>
      </ul>

      <h2>Tech I use</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 my-6">
        {technologies.map((tech) => (
          <div class="bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 px-3 py-2 rounded-lg text-center text-sm">
            {tech}
          </div>
        ))}
      </div>

      <h2>Find me</h2>
      <p>
        If you want to chat about code, projects, or anything tech — reach out.
      </p>

      <div class="flex flex-wrap gap-3 mt-6">
        <a href="https://github.com/1mangesh1" class="inline-flex items-center gap-2 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 px-4 py-2 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">
          <span>🐙</span> GitHub
        </a>
        <a href="https://x.com/Mangesh_Bide" class="inline-flex items-center gap-2 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 px-4 py-2 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">
          <span>🐦</span> Twitter
        </a>
        <a href="mailto:hello@mangeshbide.tech" class="inline-flex items-center gap-2 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 px-4 py-2 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">
          <span>📧</span> Email
        </a>
      </div>
    </div>
  </div>
</Layout> 