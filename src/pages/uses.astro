---
import Layout from '../layouts/Layout.astro';

const sections = [
  {
    heading: 'Hardware',
    items: [
      { name: 'MacBook Air M1 (13")', note: 'Primary. Fanless, lasts a day.' },
      { name: 'ThinkPad T480s', note: 'Backup. Slower, but every part is replaceable.' },
    ],
  },
  {
    heading: 'Editor & terminal',
    items: [
      { name: 'Cursor', note: 'VS Code fork with model access wired in.' },
      { name: 'macOS Terminal + zsh', note: 'No frameworks, just aliases.' },
      { name: 'Git + GitHub' },
    ],
  },
  {
    heading: 'Languages & frameworks',
    items: [
      { name: 'Python, Django, DRF' },
      { name: 'TypeScript' },
      { name: 'React' },
      { name: 'Astro', note: 'This site.' },
      { name: 'Terraform' },
      { name: 'PostgreSQL' },
    ],
  },
  {
    heading: 'Services',
    items: [
      { name: 'AWS' },
      { name: 'GitHub Pages', note: 'Hosting this site.' },
      { name: 'Cloudflare', note: 'DNS and proxy.' },
    ],
  },
  {
    heading: 'Other',
    items: [
      { name: 'DBeaver', note: 'DB client.' },
      { name: 'Notion', note: 'Notes.' },
      { name: 'Figma', note: 'When I need to draw something.' },
    ],
  },
];
---

<Layout title="Uses — Mangesh Bide" description="Hardware, software, and services I use.">
  <div class="max-w-2xl mx-auto px-6 pt-16 pb-16">
    <h1 class="font-serif text-3xl font-bold tracking-tight mb-3">Uses</h1>
    <p class="text-ink-muted dark:text-neutral-400 mb-10 leading-relaxed">
      Things I use daily. Why notes where it isn't obvious.
    </p>

    <div class="space-y-10">
      {sections.map(section => (
        <section>
          <h2 class="font-serif text-sm tracking-wider uppercase text-ink-muted dark:text-neutral-500 mb-3">
            {section.heading}
          </h2>
          <ul class="space-y-2">
            {section.items.map(item => (
              <li class="flex flex-wrap items-baseline gap-x-3">
                <span class="text-ink dark:text-neutral-100">{item.name}</span>
                {item.note && (
                  <span class="text-sm text-ink-muted dark:text-neutral-500">— {item.note}</span>
                )}
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </div>
</Layout>
