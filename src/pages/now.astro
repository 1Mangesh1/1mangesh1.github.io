---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

const entries = (await getCollection('now'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const latest = entries[0];
const archive = entries.slice(1);

const latestRendered = latest ? await render(latest) : null;

const fmt = (d: Date) =>
  new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(d);

const monthFmt = (d: Date) =>
  new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long' }).format(d);

type ListKey = 'currentlyReading' | 'currentlyWatching' | 'currentlyLearning' | 'currentlyBuilding';
const sidebarFields: { key: ListKey; label: string }[] = [
  { key: 'currentlyReading', label: 'Reading' },
  { key: 'currentlyWatching', label: 'Watching' },
  { key: 'currentlyLearning', label: 'Learning' },
  { key: 'currentlyBuilding', label: 'Building' },
];
---

<Layout title="Now — Mangesh Bide" description="What I'm doing and focused on right now.">
  <article class="max-w-2xl mx-auto px-6 pt-16 pb-8">
    <h1 class="font-serif text-3xl font-bold tracking-tight mb-2">Now</h1>
    <p class="text-sm text-ink-muted dark:text-neutral-500 mb-10">
      What I'm doing right now.
      Inspired by <a href="https://nownownow.com/about" class="hover:text-forest dark:hover:text-forest-dark underline underline-offset-4">Derek Sivers' /now page</a>.
    </p>

    {latest ? (
      <>
        <header class="mb-8">
          <h2 class="font-serif text-2xl font-bold tracking-tight mb-2">{latest.data.title}</h2>
          <div class="text-sm text-ink-muted dark:text-neutral-500 font-mono flex flex-wrap gap-x-4">
            <time datetime={latest.data.date.toISOString()}>{fmt(latest.data.date)}</time>
            {latest.data.location && <span>{latest.data.location}</span>}
          </div>
        </header>

        <div class="prose dark:prose-invert">
          {latestRendered && <latestRendered.Content />}
        </div>

        <div class="mt-10 grid sm:grid-cols-2 gap-x-8 gap-y-6 text-sm">
          {sidebarFields.map(f => {
            const items = latest.data[f.key];
            return items && items.length > 0 ? (
              <div>
                <h3 class="font-serif text-xs tracking-wider uppercase text-ink-muted dark:text-neutral-500 mb-2">{f.label}</h3>
                <ul class="space-y-1">
                  {items.map(x => <li class="text-ink dark:text-neutral-300">{x}</li>)}
                </ul>
              </div>
            ) : null;
          })}
        </div>
      </>
    ) : (
      <p class="text-ink-muted dark:text-neutral-500">No updates yet.</p>
    )}

    {archive.length > 0 && (
      <section class="mt-16 pt-8 border-t border-neutral-200 dark:border-neutral-800">
        <h2 class="font-serif text-sm tracking-wider uppercase text-ink-muted dark:text-neutral-500 mb-4">Archive</h2>
        <ul class="space-y-2">
          {archive.map(entry => (
            <li class="flex items-baseline justify-between gap-6">
              <span class="text-ink dark:text-neutral-300">{entry.data.title}</span>
              <time datetime={entry.data.date.toISOString()} class="shrink-0 text-sm text-ink-muted dark:text-neutral-500 font-mono">
                {monthFmt(entry.data.date)}
              </time>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>
</Layout>
