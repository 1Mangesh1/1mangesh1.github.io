---
import Layout from '../layouts/Layout.astro';
import SkeletonBlogCard from '../components/Skeleton/SkeletonBlogCard.astro';
import SkeletonPortfolioCard from '../components/Skeleton/SkeletonPortfolioCard.astro';
import SkeletonBookCard from '../components/Skeleton/SkeletonBookCard.astro';
import SkeletonBookmarkCard from '../components/Skeleton/SkeletonBookmarkCard.astro';
import SkeletonTilCard from '../components/Skeleton/SkeletonTilCard.astro';
import SkeletonSnippetCard from '../components/Skeleton/SkeletonSnippetCard.astro';
import SkeletonResourceCard from '../components/Skeleton/SkeletonResourceCard.astro';
import SkeletonBlogListItem from '../components/Skeleton/SkeletonBlogListItem.astro';
import SkeletonLoadingBox from '../components/Skeleton/SkeletonLoadingBox.astro';
import SkeletonGrid from '../components/Skeleton/SkeletonGrid.astro';

const title = 'Skeleton Loading Demo | Mangesh Bide';
const description = 'Demo page showcasing skeleton loading components and animations';
---

<Layout title={title} description={description}>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="mb-12">
      <h1 class="text-4xl font-bold mb-4">Skeleton Loading Components</h1>
      <p class="text-gray-600 dark:text-gray-400 mb-8 max-w-2xl">
        This page demonstrates the skeleton loading system used across the site. Skeletons provide visual feedback during content loading with smooth shimmer animations.
      </p>
      
      <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800/40 rounded-lg p-4 mb-8">
        <h2 class="font-semibold text-blue-900 dark:text-blue-200 mb-2">How to Use</h2>
        <p class="text-sm text-blue-800 dark:text-blue-300">
          Skeleton components are available in <code class="bg-blue-100 dark:bg-blue-800/50 px-2 py-1 rounded">src/components/Skeleton/</code>. Import and use them to show loading states for content before it renders.
        </p>
      </div>
    </div>

    <!-- Generic Skeleton Box -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">Generic Skeleton Box</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        Use <code class="bg-gray-100 dark:bg-gray-800 px-2 py-1 rounded">SkeletonLoadingBox</code> for flexible, custom-sized placeholders:
      </p>
      <div class="space-y-3 bg-gray-50 dark:bg-gray-900/30 p-6 rounded-lg border border-gray-200 dark:border-gray-700">
        <SkeletonLoadingBox width="w-3/4" height="h-6" pulse={1} />
        <SkeletonLoadingBox width="w-full" height="h-4" pulse={2} />
        <SkeletonLoadingBox width="w-5/6" height="h-4" pulse={3} />
      </div>
    </section>

    <!-- Blog Card Skeletons -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">Blog Cards (Featured Layout)</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        3-column grid layout used on homepage and blog listing pages:
      </p>
      <div class="grid md:grid-cols-3 gap-6">
        <SkeletonBlogCard pulse={1} />
        <SkeletonBlogCard pulse={2} />
        <SkeletonBlogCard pulse={3} />
      </div>
    </section>

    <!-- Blog List Skeletons -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">Blog List Items</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        Vertical list layout for blog pagination pages:
      </p>
      <div class="space-y-8">
        <SkeletonBlogListItem pulse={1} />
        <SkeletonBlogListItem pulse={2} />
        <SkeletonBlogListItem pulse={3} />
      </div>
    </section>

    <!-- Portfolio Card Skeletons -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">Portfolio Cards</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        2-column grid layout for project showcase:
      </p>
      <div class="grid md:grid-cols-2 gap-8">
        <SkeletonPortfolioCard pulse={1} />
        <SkeletonPortfolioCard pulse={2} />
      </div>
    </section>

    <!-- Book Card Skeletons -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">Book Cards</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        Multi-column grid for reading list and book collections:
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        <SkeletonBookCard pulse={1} />
        <SkeletonBookCard pulse={2} />
        <SkeletonBookCard pulse={3} />
        <SkeletonBookCard pulse={4} />
      </div>
    </section>

    <!-- Bookmark Card Skeletons -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">Bookmark Cards</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        2-column grid for bookmarked links and resources:
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <SkeletonBookmarkCard pulse={1} />
        <SkeletonBookmarkCard pulse={2} />
        <SkeletonBookmarkCard pulse={3} />
        <SkeletonBookmarkCard pulse={4} />
      </div>
    </section>

    <!-- TIL Card Skeletons -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">TIL (Today I Learned) Cards</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        Vertical list for daily learnings:
      </p>
      <div class="space-y-6">
        <SkeletonTilCard pulse={1} />
        <SkeletonTilCard pulse={2} />
        <SkeletonTilCard pulse={3} />
      </div>
    </section>

    <!-- Snippet Card Skeletons -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">Code Snippet Cards</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        2-column grid for code pattern collections:
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <SkeletonSnippetCard pulse={1} />
        <SkeletonSnippetCard pulse={2} />
        <SkeletonSnippetCard pulse={3} />
        <SkeletonSnippetCard pulse={4} />
      </div>
    </section>

    <!-- Resource Card Skeletons -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">Resource Cards</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        Large format for featured resources and articles:
      </p>
      <div class="space-y-6">
        <SkeletonResourceCard pulse={1} />
        <SkeletonResourceCard pulse={2} />
        <SkeletonResourceCard pulse={3} />
      </div>
    </section>

    <!-- Skeleton Grid Utility -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">SkeletonGrid Utility</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        The <code class="bg-gray-100 dark:bg-gray-800 px-2 py-1 rounded">SkeletonGrid</code> component automatically generates a grid of skeletons with the correct layout for any content type:
      </p>
      <div class="mb-8">
        <h3 class="font-semibold mb-3 text-sm text-gray-700 dark:text-gray-300">Usage Example:</h3>
        <pre class="bg-gray-900 text-gray-100 p-4 rounded-lg text-sm overflow-x-auto"><code>{`<SkeletonGrid type="blog" count={6} />`}</code></pre>
      </div>
      <div class="mb-8">
        <h3 class="font-semibold mb-3 text-sm text-gray-700 dark:text-gray-300">Available types:</h3>
        <ul class="list-disc list-inside space-y-1 text-gray-700 dark:text-gray-300 text-sm">
          <li><code class="bg-gray-100 dark:bg-gray-800 px-1 rounded">blog</code> - 3-column blog card grid</li>
          <li><code class="bg-gray-100 dark:bg-gray-800 px-1 rounded">portfolio</code> - 2-column portfolio grid</li>
          <li><code class="bg-gray-100 dark:bg-gray-800 px-1 rounded">book</code> - 4-column book grid</li>
          <li><code class="bg-gray-100 dark:bg-gray-800 px-1 rounded">bookmark</code> - 2-column bookmark grid</li>
          <li><code class="bg-gray-100 dark:bg-gray-800 px-1 rounded">til</code> - List of TIL items</li>
          <li><code class="bg-gray-100 dark:bg-gray-800 px-1 rounded">snippet</code> - 2-column snippet grid</li>
          <li><code class="bg-gray-100 dark:bg-gray-800 px-1 rounded">resource</code> - List of resources</li>
          <li><code class="bg-gray-100 dark:bg-gray-800 px-1 rounded">blog-list</code> - Blog listing (vertical)</li>
        </ul>
      </div>
    </section>

    <!-- CSS Classes -->
    <section>
      <h2 class="text-2xl font-bold mb-6">Available CSS Classes</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        Skeleton utilities available globally via <code class="bg-gray-100 dark:bg-gray-800 px-2 py-1 rounded">public/animations.css</code>:
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-gray-50 dark:bg-gray-900/30 p-4 rounded-lg border border-gray-200 dark:border-gray-700">
          <h3 class="font-semibold mb-3 text-sm">Base Classes</h3>
          <ul class="space-y-2 text-sm text-gray-700 dark:text-gray-300">
            <li><code class="bg-gray-100 dark:bg-gray-800 px-2 py-1 rounded">.skeleton</code> - Base shimmer animation</li>
            <li><code class="bg-gray-100 dark:bg-gray-800 px-2 py-1 rounded">.skeleton-text</code> - Text placeholder</li>
            <li><code class="bg-gray-100 dark:bg-gray-800 px-2 py-1 rounded">.skeleton-image</code> - Image placeholder</li>
            <li><code class="bg-gray-100 dark:bg-gray-800 px-2 py-1 rounded">.skeleton-button</code> - Button placeholder</li>
            <li><code class="bg-gray-100 dark:bg-gray-800 px-2 py-1 rounded">.skeleton-round</code> - Circular avatar</li>
          </ul>
        </div>
        <div class="bg-gray-50 dark:bg-gray-900/30 p-4 rounded-lg border border-gray-200 dark:border-gray-700">
          <h3 class="font-semibold mb-3 text-sm">Stagger Delays</h3>
          <ul class="space-y-2 text-sm text-gray-700 dark:text-gray-300">
            <li><code class="bg-gray-100 dark:bg-gray-800 px-2 py-1 rounded">.skeleton-pulse-1</code> - No delay</li>
            <li><code class="bg-gray-100 dark:bg-gray-800 px-2 py-1 rounded">.skeleton-pulse-2</code> - 0.1s delay</li>
            <li><code class="bg-gray-100 dark:bg-gray-800 px-2 py-1 rounded">.skeleton-pulse-3</code> - 0.2s delay</li>
            <li><code class="bg-gray-100 dark:bg-gray-800 px-2 py-1 rounded">.skeleton-pulse-4</code> - 0.3s delay</li>
            <li><code class="bg-gray-100 dark:bg-gray-800 px-2 py-1 rounded">.skeleton-pulse-5</code> - 0.4s delay</li>
          </ul>
        </div>
      </div>
    </section>
  </div>
</Layout>
