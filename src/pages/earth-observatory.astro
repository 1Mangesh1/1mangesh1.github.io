---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Earth Observatory | Mangesh Bide" description="Live 3D globe showing real-time natural events from NASA's EONET — wildfires, storms, volcanoes, and more, tracked as they happen.">
  <div class="max-w-5xl mx-auto px-4 py-12">

    <!-- Header -->
    <div class="text-center mb-10">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-3 tracking-tight">
        <span class="custom-gradient-bg">Earth Observatory</span>
      </h1>
      <p class="text-lg text-gray-500 dark:text-gray-400 max-w-xl mx-auto">
        Live natural events tracked by NASA's
        <a href="https://eonet.gsfc.nasa.gov/" target="_blank" rel="noopener" class="underline decoration-dotted hover:text-emerald-600 dark:hover:text-cyan-400 transition-colors">EONET</a>
      </p>
    </div>

    <!-- Stats Bar -->
    <div id="globe-stats" class="flex justify-center gap-6 md:gap-10 mb-8 text-sm">
      <div class="stat-item">
        <span id="stat-total" class="stat-value">--</span>
        <span class="stat-label">Events</span>
      </div>
      <div class="stat-item">
        <span id="stat-active" class="stat-value">--</span>
        <span class="stat-label">Active</span>
      </div>
      <div class="stat-item">
        <span id="stat-categories" class="stat-value">--</span>
        <span class="stat-label">Categories</span>
      </div>
      <div class="stat-item">
        <span id="stat-updated" class="stat-value">--</span>
        <span class="stat-label">Updated</span>
      </div>
    </div>

    <!-- Globe Section -->
    <div class="globe-wrapper mb-6">
      <div class="globe-outer">
        <div id="globe-mount" class="globe-mount"></div>

        <!-- Loading overlay -->
        <div id="globe-loading" class="globe-loading">
          <div class="loading-spinner"></div>
          <p class="loading-text">Loading Earth...</p>
        </div>

        <!-- Error state -->
        <div id="globe-error" class="globe-error"></div>
      </div>
      <p class="text-center text-xs text-gray-400 dark:text-gray-500 mt-3">
        Drag to rotate &middot; Scroll to zoom &middot; Hover for details &middot; Click markers to view event
      </p>
    </div>

    <!-- Category Filters -->
    <div class="mb-8">
      <div id="category-filters" class="category-filters"></div>
    </div>

    <!-- Event List -->
    <div class="events-section">
      <h2 class="text-xl font-bold mb-4 text-gray-800 dark:text-gray-200">Recent Events</h2>

      <div id="events-loading" class="events-loading">
        <div class="skel-card"><div class="skel-dot"></div><div class="skel-lines"><div class="skel-line w-3/4"></div><div class="skel-line w-1/2"></div></div></div>
        <div class="skel-card"><div class="skel-dot"></div><div class="skel-lines"><div class="skel-line w-2/3"></div><div class="skel-line w-1/3"></div></div></div>
        <div class="skel-card"><div class="skel-dot"></div><div class="skel-lines"><div class="skel-line w-4/5"></div><div class="skel-line w-2/5"></div></div></div>
        <div class="skel-card"><div class="skel-dot"></div><div class="skel-lines"><div class="skel-line w-1/2"></div><div class="skel-line w-1/4"></div></div></div>
      </div>

      <div id="events-container" class="events-container"></div>
    </div>

    <!-- Attribution -->
    <div class="text-center mt-12 text-xs text-gray-400 dark:text-gray-600">
      Data from <a href="https://eonet.gsfc.nasa.gov/" target="_blank" rel="noopener" class="underline hover:text-emerald-600 dark:hover:text-cyan-400">NASA EONET v3</a> &middot; Updated in real-time
    </div>
  </div>

  <script is:inline src="/scripts/earth-observatory.js"></script>
</Layout>

<style is:global>
  /* ─── Stats ─────────────────────────────────────────── */
  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }
  .stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: #111827;
    font-variant-numeric: tabular-nums;
  }
  .stat-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #9ca3af;
  }
  html.dark .stat-value { color: #e5e7eb; }

  /* ─── Globe ─────────────────────────────────────────── */
  .globe-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .globe-outer {
    position: relative;
    width: 100%;
    max-width: 700px;
  }
  .globe-mount {
    width: 100%;
    min-height: 400px;
  }
  /* globe.gl renders a canvas inside — make sure it's responsive */
  .globe-mount canvas {
    cursor: grab;
    outline: none;
  }
  .globe-mount canvas:active {
    cursor: grabbing;
  }

  /* Loading overlay */
  .globe-loading {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    z-index: 10;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }
  .loading-spinner {
    width: 40px;
    height: 40px;
    border: 3px solid rgba(100, 160, 240, 0.2);
    border-top-color: #3b82f6;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  .loading-text {
    font-size: 0.8rem;
    color: #64748b;
  }

  /* Error */
  .globe-error {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.9);
    z-index: 15;
  }
  html.dark .globe-error {
    background: rgba(11, 15, 26, 0.9);
  }
  .error-content {
    text-align: center;
    padding: 2rem;
  }
  .error-icon {
    font-size: 3rem;
    margin-bottom: 0.5rem;
  }
  .error-msg {
    color: #94a3b8;
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }
  .retry-btn {
    padding: 0.5rem 1.5rem;
    border-radius: 0.5rem;
    background: #1e293b;
    color: #e2e8f0;
    font-size: 0.85rem;
    border: 1px solid #334155;
    cursor: pointer;
    transition: background 0.2s;
  }
  .retry-btn:hover { background: #334155; }

  /* ─── Category Filters ──────────────────────────────── */
  .category-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
  }
  .category-toggle {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 500;
    border: 1px solid #e5e7eb;
    background: #fff;
    color: #6b7280;
    cursor: pointer;
    transition: all 0.2s ease;
    user-select: none;
  }
  .category-toggle:hover {
    border-color: #d1d5db;
    background: #f9fafb;
  }
  .category-toggle.active {
    border-color: #3b82f6;
    background: #eff6ff;
    color: #1e40af;
  }
  html.dark .category-toggle {
    border-color: #374151;
    background: #1f2937;
    color: #9ca3af;
  }
  html.dark .category-toggle:hover {
    border-color: #4b5563;
    background: #283548;
  }
  html.dark .category-toggle.active {
    border-color: #3b82f6;
    background: rgba(59, 130, 246, 0.15);
    color: #93c5fd;
  }
  .cat-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ─── Event Cards ───────────────────────────────────── */
  .events-container {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .event-card {
    padding: 14px 16px;
    border-radius: 12px;
    border: 1px solid #e5e7eb;
    background: #fff;
    transition: all 0.2s ease;
    cursor: pointer;
  }
  .event-card:hover {
    border-color: #93c5fd;
    box-shadow: 0 2px 12px rgba(59, 130, 246, 0.08);
  }
  html.dark .event-card {
    background: #111827;
    border-color: #1e293b;
  }
  html.dark .event-card:hover {
    border-color: #2563eb;
    box-shadow: 0 2px 16px rgba(59, 130, 246, 0.1);
  }
  .event-card.flash-highlight {
    animation: card-flash 1.5s ease;
  }
  @keyframes card-flash {
    0% { box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.5); }
    100% { box-shadow: none; }
  }
  .event-card-inner {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }
  .event-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 6px;
  }
  .event-info {
    flex: 1;
    min-width: 0;
  }
  .event-title {
    font-size: 0.92rem;
    font-weight: 600;
    color: #111827;
    margin: 0 0 4px;
    line-height: 1.3;
  }
  html.dark .event-title { color: #e5e7eb; }
  .event-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 14px;
    font-size: 0.75rem;
    color: #6b7280;
  }
  html.dark .event-meta { color: #9ca3af; }
  .event-category { font-weight: 500; }
  .status-open { color: #22c55e; }
  .status-closed { color: #ef4444; }
  .event-source {
    display: inline-block;
    margin-top: 4px;
    font-size: 0.72rem;
    color: #3b82f6;
    text-decoration: none;
    transition: color 0.15s;
  }
  .event-source:hover { color: #2563eb; text-decoration: underline; }
  html.dark .event-source { color: #60a5fa; }
  html.dark .event-source:hover { color: #93c5fd; }
  .empty-state {
    text-align: center;
    padding: 2rem;
    color: #9ca3af;
    font-size: 0.9rem;
  }

  /* ─── Skeleton Loading ──────────────────────────────── */
  .events-loading {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .skel-card {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 14px 16px;
    border-radius: 12px;
    border: 1px solid #e5e7eb;
    background: #fff;
  }
  html.dark .skel-card {
    background: #111827;
    border-color: #1e293b;
  }
  .skel-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #e5e7eb;
    flex-shrink: 0;
    margin-top: 4px;
    animation: skel-pulse 1.5s ease-in-out infinite;
  }
  html.dark .skel-dot { background: #1e293b; }
  .skel-lines {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .skel-line {
    height: 12px;
    border-radius: 6px;
    background: #e5e7eb;
    animation: skel-pulse 1.5s ease-in-out infinite;
  }
  html.dark .skel-line { background: #1e293b; }
  @keyframes skel-pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.8; }
  }

  /* ─── Responsive ────────────────────────────────────── */
  @media (max-width: 640px) {
    .globe-outer { max-width: 100%; }
    .globe-mount { min-height: 300px; }
    .stat-value { font-size: 1.2rem; }
    .category-filters {
      justify-content: flex-start;
      overflow-x: auto;
      flex-wrap: nowrap;
      padding-bottom: 4px;
      -webkit-overflow-scrolling: touch;
    }
    .category-toggle { flex-shrink: 0; }
  }
</style>
