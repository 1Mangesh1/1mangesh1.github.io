---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => data.draft !== true))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 6);

const projects = (await getCollection('portfolio'))
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const fmt = (d: Date) =>
  new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' }).format(d);
---

<Layout title="Mangesh Bide" description="Software engineer. Python, Django, infrastructure. Writing about what I build and learn.">
  <article class="max-w-2xl mx-auto px-6 pt-16 pb-8">
    <p class="text-lg leading-relaxed text-ink dark:text-neutral-200">
      Software engineer working on backend systems and infrastructure —
      Python, Django, AWS. Currently at Houseworks Technologies building
      healthcare APIs. I write about what I ship, the tools I pick up,
      and the problems that keep me up.
    </p>
  </article>

  <section class="max-w-2xl mx-auto px-6 py-8">
    <h2 class="font-serif text-sm tracking-wider uppercase text-ink-muted dark:text-neutral-500 mb-5">Writing</h2>
    <ul class="space-y-4">
      {posts.map(post => (
        <li class="flex items-baseline justify-between gap-6">
          <a href={`/blog/${post.id}`} class="text-ink dark:text-neutral-100 hover:text-forest dark:hover:text-forest-dark underline-offset-4 decoration-transparent hover:decoration-forest/50 dark:hover:decoration-forest-dark/50 underline">
            {post.data.title}
          </a>
          <time datetime={post.data.pubDate.toISOString()} class="shrink-0 text-sm text-ink-muted dark:text-neutral-500 font-mono">
            {fmt(post.data.pubDate)}
          </time>
        </li>
      ))}
    </ul>
    <p class="mt-6 text-sm">
      <a href="/blog" class="text-ink-muted dark:text-neutral-400 hover:text-forest dark:hover:text-forest-dark">All posts →</a>
    </p>
  </section>

  <section class="max-w-2xl mx-auto px-6 py-8">
    <h2 class="font-serif text-sm tracking-wider uppercase text-ink-muted dark:text-neutral-500 mb-5">Projects</h2>
    <ul class="space-y-5">
      {projects.map(project => (
        <li>
          <a href={`/projects/${project.id}`} class="block group">
            <div class="flex items-baseline justify-between gap-4 mb-1">
              <span class="text-ink dark:text-neutral-100 group-hover:text-forest dark:group-hover:text-forest-dark underline underline-offset-4 decoration-transparent group-hover:decoration-forest/50 dark:group-hover:decoration-forest-dark/50">
                {project.data.title}
              </span>
              <span class="shrink-0 text-xs text-ink-muted dark:text-neutral-500 font-mono">
                {project.data.tech.slice(0, 3).join(' · ')}
              </span>
            </div>
            <p class="text-sm text-ink-muted dark:text-neutral-400 leading-relaxed">
              {project.data.description}
            </p>
          </a>
        </li>
      ))}
    </ul>
    <p class="mt-6 text-sm">
      <a href="/projects" class="text-ink-muted dark:text-neutral-400 hover:text-forest dark:hover:text-forest-dark">All projects →</a>
    </p>
  </section>
</Layout>
